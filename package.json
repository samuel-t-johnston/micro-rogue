{
  "name": "rogue",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "description": "Micro-Rogue (stylized ROGµE) — a game engine for traditional roguelike games written in vanilla JavaScript and HTML.",
  "scripts": {
    "predev": "node scripts/check-port.mjs 8000",
    "dev": "live-server --port=8000 --no-browser --ignore=node_modules",
    "dev:kill": "kill-port 8000",
    "dev:fresh": "npm run dev:kill && npm run dev",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage.enabled --coverage.provider=v8 --coverage.reporter=text --coverage.include=src/** --coverage.exclude=src/**/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "visualize": "node scripts/visualize-generation.mjs",
    "sprite:preview": "node scripts/sprite-preview.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.7",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "kill-port": "^2.0.1",
    "live-server": "^1.2.2",
    "prettier": "^3.8.4",
    "vitest": "^4.1.9"
  }
}
